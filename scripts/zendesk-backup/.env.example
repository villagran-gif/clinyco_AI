# Subdominio de Zendesk (sin .zendesk.com)
# Ejemplo: si tu URL es https://miempresa.zendesk.com → ZENDESK_SUBDOMAIN=miempresa
ZENDESK_SUBDOMAIN=

# Email del usuario Owner
ZENDESK_EMAIL=

# API Token generado en:
# Admin Center → Apps and integrations → APIs → Zendesk API → Settings → Add API token
ZENDESK_API_TOKEN=

# Carpeta destino del backup (relativa o absoluta)
ZENDESK_BACKUP_DIR=./backup-output

# Si descargar adjuntos a disco (true/false). Pueden pesar mucho.
ZENDESK_DOWNLOAD_ATTACHMENTS=true

# Epoch unix desde donde empezar el export incremental.
# 0 = desde el inicio de la cuenta (recomendado para backup completo).
ZENDESK_INCREMENTAL_START_TIME=0

# Concurrencia de descargas paralelas (default 5)
ZENDESK_CONCURRENCY=5
