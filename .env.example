OPENAI_API_KEY=your_openai_api_key_here
PORT=3000
CLINYCO_DEBUG_BASE_URL=https://clinyco-ai.onrender.com
CLINYCO_DEBUG_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
EUGENIA_FEEDBACK_SHEET_TAB=faq_por_resolver
EUGENIA_FEEDBACK_SHEET_URL=
KNOWLEDGE_SYNC_KEY=
KNOWLEDGE_SYNC_TIMEOUT_MS=180000

# Anthropic API — Used by EugenIA (evaluate.js) and sentiment LLM
ANTHROPIC_API_KEY=

# Sentiment LLM pipeline (WAHA)
SENTIMENT_LLM_ENABLED=true
SENTIMENT_LLM_MODEL=claude-haiku-4-5-20251001
SENTIMENT_LLM_TIMEOUT_MS=3000
SENTIMENT_LOW_CONFIDENCE_THRESHOLD=0.7
SENTIMENT_FEWSHOT_SIZE=15
SENTIMENT_DRIFT_WEBHOOK_URL=

# Mac Desktop WhatsApp call extractor
MAC_CALL_IMPORT_SECRET=

# Medinet API — JWT auth for /api-public/* endpoints
# Obtained from Medinet implementation team
MEDINET_JWT_USERNAME=
MEDINET_JWT_PASSWORD=
# Static token for /api/* endpoints (existing)
MEDINET_API_TOKEN=

# ── Telemedicine lifecycle (ciclo de recordatorios + pago + sesión) ──
# WAHA (envío de WhatsApp)
WAHA_API_URL=http://waha:3000
WAHA_API_KEY=
WAHA_SESSION_NAME=piloto-agente-1

# BICE (pago). Sin BICE_API_BASE_URL+BICE_API_KEY el cliente corre en modo stub.
BICE_API_BASE_URL=
BICE_API_KEY=
BICE_MERCHANT_ID=
BICE_CHECKOUT_BASE_URL=https://clinyco-ai.onrender.com/pay/bice

# Link de sesión de telemedicina (firmado HMAC)
TELEMEDICINE_SESSION_BASE_URL=https://telemedicina.clinyco.cl/sesion
TELEMEDICINE_SESSION_SECRET=

# Worker de recordatorios + ingesta
TELEMEDICINE_WORKER_TOKEN=
TELEMEDICINE_WORKER_PORT=8788
TELEMEDICINE_REMINDER_TICK_MS=60000
TELEMEDICINE_INGEST_INTERVAL_MS=300000
TELEMEDICINE_INGEST_DAYS_AHEAD=14
TELEMEDICINE_DEFAULT_AMOUNT_CLP=25000
