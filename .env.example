OPENAI_API_KEY=your_openai_api_key_here
PORT=3000
CLINYCO_DEBUG_BASE_URL=https://clinyco-ai.onrender.com
CLINYCO_DEBUG_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
EUGENIA_FEEDBACK_SHEET_TAB=faq_por_resolver
EUGENIA_FEEDBACK_SHEET_URL=
KNOWLEDGE_SYNC_KEY=
KNOWLEDGE_SYNC_TIMEOUT_MS=180000

# Anthropic API — Used by EugenIA (evaluate.js) and sentiment LLM
ANTHROPIC_API_KEY=

# Sentiment LLM pipeline (WAHA)
SENTIMENT_LLM_ENABLED=true
SENTIMENT_LLM_MODEL=claude-haiku-4-5-20251001
SENTIMENT_LLM_TIMEOUT_MS=3000
SENTIMENT_LOW_CONFIDENCE_THRESHOLD=0.7
SENTIMENT_FEWSHOT_SIZE=15
SENTIMENT_DRIFT_WEBHOOK_URL=

# Mac Desktop WhatsApp call extractor
MAC_CALL_IMPORT_SECRET=

# Medinet API — JWT auth for /api-public/* endpoints
# Obtained from Medinet implementation team
MEDINET_JWT_USERNAME=
MEDINET_JWT_PASSWORD=
# Static token for /api/* endpoints (existing)
MEDINET_API_TOKEN=

# Meta Ads — via Composio MCP (no direct Meta credentials needed)
# 1) Sign up at https://composio.dev and connect Meta Ads in the dashboard
#    (composio link metaads via CLI, or platform.composio.dev → Connect Apps)
# 2) Go to https://dashboard.composio.dev/<workspace>/install (Install section)
#    and copy the MCP URL and X-CONSUMER-API-KEY shown there
# 3) The CONSUMER key starts with "ck_" — NOT the "uak_" CLI user key
COMPOSIO_API_KEY=ck_
COMPOSIO_MCP_URL=https://connect.composio.dev/mcp

# Meta organic publishing — Instagram + Facebook Pages (direct Graph API)
# Uses the "chatwoot" app (App ID 1697421917913182) in Standard Access — no App
# Review needed for our own accounts under Business Manager 1969811199978170.
# System-user token scopes: instagram_business_basic,
# instagram_business_content_publish, instagram_business_manage_insights,
# pages_show_list, pages_read_engagement, pages_manage_posts
# (NOT manage_messages — that's the Messaging API and unrelated).
# Multi-page: every Page the token can reach is auto-discovered via
# /me/accounts, so no need to enumerate Page IDs here.
META_CONTENT_TOKEN=
META_API_VERSION=v21.0
# Optional: comma-separated allowlist if the token has access to more Pages
# than we want to manage. Leave empty to expose all.
META_PAGE_IDS=

# Cola fonasapad — notificaciones al Calendar de villagran@clinyco.cl.
# Reutiliza la service account de Google ya configurada para Sheets
# (GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_PRIVATE_KEY). El módulo
# queue/calendar-notify.js firma JWT RS256 contra oauth2.googleapis.com
# y llama Calendar API directamente — no requiere paquete googleapis.
#
# Estrategias en orden:
#  1. Domain-wide delegation: si el admin de Workspace de clinyco.cl
#     autoriza al service account a impersonar a villagran@clinyco.cl
#     con scope calendar.events, el evento aparece en su calendario
#     primario directo.
FONASAPAD_CALENDAR_USE_DWD=false
#  2. Fallback (cero admin work): creamos el evento en el calendario
#     del service account y agregamos villagran@ como attendee con
#     sendUpdates=all. Google le manda invitación por mail; al
#     Aceptar entra al calendario propio.
FONASAPAD_CALENDAR_USER=villagran@clinyco.cl
FONASAPAD_CALENDAR_EXTRA_ATTENDEE=
# Opcional: si quieres especificar el calendario destino del fallback.
FONASAPAD_CALENDAR_ID=primary
# Activa el cron interno que selecciona y notifica al sweet-spot diario.
# Lun-Vie 09:00 Chile, Sáb/Dom 10:00. Si quieres correrlo en un worker
# aparte, deja esto en false.
FONASAPAD_CRON_ENABLED=false
# URL pública del sitio para construir los enlaces aprobar/rechazar
# del evento Calendar. Default: https://clinyco-ai.netlify.app
PUBLIC_BASE_URL=https://clinyco-ai.netlify.app
