OPENAI_API_KEY=your_openai_api_key_here
PORT=3000
CLINYCO_DEBUG_BASE_URL=https://clinyco-ai.onrender.com
CLINYCO_DEBUG_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
EUGENIA_FEEDBACK_SHEET_TAB=faq_por_resolver
EUGENIA_FEEDBACK_SHEET_URL=
KNOWLEDGE_SYNC_KEY=
KNOWLEDGE_SYNC_TIMEOUT_MS=180000

# Anthropic API — Used by EugenIA (evaluate.js) and sentiment LLM
ANTHROPIC_API_KEY=

# Sentiment LLM pipeline (WAHA)
SENTIMENT_LLM_ENABLED=true
SENTIMENT_LLM_MODEL=claude-haiku-4-5-20251001
SENTIMENT_LLM_TIMEOUT_MS=3000
SENTIMENT_LOW_CONFIDENCE_THRESHOLD=0.7
SENTIMENT_FEWSHOT_SIZE=15
SENTIMENT_DRIFT_WEBHOOK_URL=

# Mac Desktop WhatsApp call extractor
MAC_CALL_IMPORT_SECRET=

# Medinet API — JWT auth for /api-public/* endpoints
# Obtained from Medinet implementation team
MEDINET_JWT_USERNAME=
MEDINET_JWT_PASSWORD=
# Static token for /api/* endpoints (existing)
MEDINET_API_TOKEN=

# Meta Ads — Marketing API (Graph API)
# Long-lived System User token recommended (Business Manager > System Users)
# Required scopes: ads_read, ads_management, business_management
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
# Optional: pin a primary account (e.g. act_123456789). If empty, bootstrap()
# auto-discovers via /me/adaccounts and uses the first one returned.
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0
