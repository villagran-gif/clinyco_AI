# WAHA
WAHA_API_KEY=cambiar-por-key-seguro
WAHA_DASHBOARD_USER=admin
WAHA_DASHBOARD_PASS=cambiar-por-password-seguro

# Observer
PORT=3001
DATABASE_URL=postgres://user:pass@host.docker.internal:5432/clinyco
WAHA_API_URL=http://waha:3000
DEFAULT_SESSION_NAME=piloto-agente-1
DEFAULT_AGENT_NAME=Agente Piloto

# Sentiment LLM (requires Anthropic API key)
ANTHROPIC_API_KEY=
SENTIMENT_LLM_ENABLED=true
